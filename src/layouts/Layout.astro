---
interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = '', bodyClass = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%230A0A0F'/%3E%3Ctext x='50%25' y='58%25' font-family='Georgia,serif' font-size='18' font-style='italic' fill='%23E8A87C' text-anchor='middle'%3EF%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=JetBrains+Mono:wght@400;500;600&family=Geist:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
